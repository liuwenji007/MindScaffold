{
  "mcpServers": {
    "apifox-local": {
      "command": "npx",
      "args": [
        "-y",
        "apifox-mcp-server@latest",
        "--oas=http://localhost:3456/default_OpenAPI.json"
      ]
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp"
    },
    "lark-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@larksuiteoapi/lark-mcp",
        "mcp",
        "-a",
        "${FEISHU_APP_ID}",
        "-s",
        "${FEISHU_APP_SECRET}",
        "--oauth"
      ],
      "disabled": false
    },
    "apifox": {
      "command": "npx",
      "args": [
        "-y",
        "apifox-mcp-server@latest",
        "--oas=${APIFOX_OAS_URL}"
      ],
      "disabled": false
    }
  }
}
